{
  "id": "wechatpadpro",
  "kind": "channel",
  "channels": ["wechatpadpro"],
  "name": "WeChatPadPro",
  "description": "OpenClaw channel plugin for WeChatPadPro / WeChatPadProMax",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "wechatpadpro": {
        "type": "object",
        "properties": {
          "host": {
            "type": "string",
            "description": "WeChatPadPro server host (e.g. 192.168.1.100)",
            "x-openclaw-order": 1,
            "x-openclaw-group": "Server Connection",
            "x-openclaw-placeholder": "192.168.1.100"
          },
          "port": {
            "type": "number",
            "description": "WeChatPadPro server port",
            "default": 8062,
            "x-openclaw-order": 2,
            "x-openclaw-group": "Server Connection"
          },
          "adminKey": {
            "type": "string",
            "description": "WeChatPadPro admin key (required for WS mode only)",
            "x-openclaw-order": 3,
            "x-openclaw-group": "Authentication",
            "x-openclaw-secret": true
          },
          "authKey": {
            "type": "string",
            "description": "Pre-generated auth key for standard WCPP (optional, auto-generates if not set)",
            "x-openclaw-order": 4,
            "x-openclaw-group": "Authentication",
            "x-openclaw-secret": true
          },
          "authcode": {
            "type": "string",
            "description": "WeChatPadProMAX authcode (required for sync/websocket/webhook mode)",
            "x-openclaw-order": 5,
            "x-openclaw-group": "Authentication",
            "x-openclaw-secret": true
          },
          "wxid": {
            "type": "string",
            "description": "WeChat ID (optional, auto-detected from Newinit response)",
            "x-openclaw-order": 6,
            "x-openclaw-group": "Authentication"
          },
          "syncMode": {
            "type": "string",
            "enum": ["ws", "sync", "websocket", "webhook"],
            "description": "Message sync mode: 'ws' = WebSocket (standard WCPP), 'sync' = HTTP polling (WCPP MAX), 'websocket' = WebSocket push (WCPP MAX), 'webhook' = HTTP push from WCPP MAX. Auto-detected from authcode if not set.",
            "x-openclaw-order": 10,
            "x-openclaw-group": "Sync Mode",
            "x-openclaw-enumLabels": {
              "ws": "WebSocket (standard WCPP)",
              "sync": "HTTP Polling (WCPP MAX)",
              "websocket": "WebSocket Push (WCPP MAX)",
              "webhook": "Webhook Push (WCPP MAX)"
            }
          },
          "syncInterval": {
            "type": "number",
            "description": "Poll interval in ms for sync mode",
            "default": 5000,
            "x-openclaw-order": 11,
            "x-openclaw-group": "Sync Mode",
            "x-openclaw-showWhen": { "syncMode": "sync" }
          },
          "wsUrl": {
            "type": "string",
            "description": "Custom WebSocket URL for websocket mode (default: ws://{host}:8089/ws/sync)",
            "x-openclaw-order": 12,
            "x-openclaw-group": "Sync Mode",
            "x-openclaw-placeholder": "ws://host:8089/ws/sync",
            "x-openclaw-showWhen": { "syncMode": "websocket" }
          },
          "wsFallbackThreshold": {
            "type": "number",
            "description": "Consecutive WebSocket failures before falling back to HTTP polling",
            "default": 3,
            "x-openclaw-order": 13,
            "x-openclaw-group": "Sync Mode",
            "x-openclaw-showWhen": { "syncMode": "websocket" }
          },
          "webhookUrl": {
            "type": "string",
            "description": "URL for WCPP MAX to POST messages to (required for webhook mode)",
            "x-openclaw-order": 14,
            "x-openclaw-group": "Webhook",
            "x-openclaw-placeholder": "http://YOUR_IP:8000/webhook",
            "x-openclaw-showWhen": { "syncMode": "webhook" }
          },
          "webhookPort": {
            "type": "number",
            "description": "Local HTTP server port for receiving webhook pushes",
            "default": 8000,
            "x-openclaw-order": 15,
            "x-openclaw-group": "Webhook",
            "x-openclaw-showWhen": { "syncMode": "webhook" }
          },
          "webhookPath": {
            "type": "string",
            "description": "Path for webhook endpoint (default: /webhook)",
            "x-openclaw-order": 16,
            "x-openclaw-group": "Webhook",
            "x-openclaw-showWhen": { "syncMode": "webhook" }
          },
          "webhookSecret": {
            "type": "string",
            "description": "HMAC-SHA256 secret for webhook signature verification (optional but recommended)",
            "x-openclaw-order": 17,
            "x-openclaw-group": "Webhook",
            "x-openclaw-secret": true,
            "x-openclaw-showWhen": { "syncMode": "webhook" }
          },
          "newinitOnStart": {
            "type": "boolean",
            "description": "Call Newinit on startup to establish longlink (required for WCPP MAX 0412+)",
            "default": true,
            "x-openclaw-order": 20,
            "x-openclaw-group": "Advanced"
          },
          "readOnly": {
            "type": "boolean",
            "description": "Receive-only mode — blocks all outbound sends for account safety",
            "default": false,
            "x-openclaw-order": 21,
            "x-openclaw-group": "Advanced"
          },
          "maxMessageAge": {
            "type": "number",
            "description": "Drop messages older than this many seconds (avoids replaying stale history)",
            "default": 180,
            "x-openclaw-order": 22,
            "x-openclaw-group": "Advanced"
          },
          "dmSecurity": {
            "type": "string",
            "enum": ["allowlist", "allow-all", "pairing"],
            "description": "DM security policy",
            "default": "allowlist",
            "x-openclaw-order": 30,
            "x-openclaw-group": "Security",
            "x-openclaw-enumLabels": {
              "allowlist": "Allowlist Only",
              "allow-all": "Allow All",
              "pairing": "Pairing Required"
            }
          },
          "allowFrom": {
            "type": "array",
            "items": { "type": "string" },
            "description": "List of wxid allowed to DM the bot (used when dmSecurity = allowlist)",
            "x-openclaw-order": 31,
            "x-openclaw-group": "Security",
            "x-openclaw-showWhen": { "dmSecurity": "allowlist" }
          },
          "allowMsgTypes": {
            "type": "array",
            "items": { "type": "number" },
            "description": "Message types to pass through (default: 1=text, 3=image, 34=voice, 47=sticker, 48=location, 49=app)",
            "default": [1, 3, 34, 47, 48, 49],
            "x-openclaw-order": 32,
            "x-openclaw-group": "Security"
          },
          "passRevokemsg": {
            "type": "boolean",
            "description": "Pass through message recall notifications (MsgType 10002 revokemsg)",
            "default": true,
            "x-openclaw-order": 33,
            "x-openclaw-group": "Security"
          },
          "replyWithMention": {
            "type": "boolean",
            "description": "In group chats, prefix reply with @sender mention",
            "default": false,
            "x-openclaw-order": 40,
            "x-openclaw-group": "Behavior"
          },
          "proxy": {
            "type": "string",
            "description": "Proxy URL (e.g. socks5://user:pass@host:port)",
            "x-openclaw-order": 50,
            "x-openclaw-group": "Advanced",
            "x-openclaw-placeholder": "socks5://user:pass@host:port"
          }
        },
        "required": ["host"]
      }
    }
  }
}
